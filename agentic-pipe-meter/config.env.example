# Agentic Pipe Meter — configuration file
# Copy this to config.env and fill in your values.
# Usage: python3 pipe_meter.py --config config.env
#        uv run pipe_meter.py --config config.env
#
# CLI flags always override values defined here.
# Lines starting with # are ignored. Inline # comments are also supported.

# ---- Azure subscription & resource group ------------------------------------

SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
RESOURCE_GROUP="my-resource-group"
LOCATION="eastus"

# ---- Network topology -------------------------------------------------------

VNET_NAME="my-vnet"
SUBNET_NAME="default"

# ---- Source VM --------------------------------------------------------------

SOURCE_VM_PRIVATE_IP="10.0.0.4"
SOURCE_VM_PUBLIC_IP="20.30.40.50"    # used for SSH if running from outside the VNet
SOURCE_VM_NSG_NAME="source-vm-nsg"

# ---- Destination VM ---------------------------------------------------------

DEST_VM_PRIVATE_IP="10.0.0.5"
DEST_VM_NSG_NAME="dest-vm-nsg"

# ---- SSH credentials --------------------------------------------------------

SSH_USER="azureuser"
SSH_SOURCE_VM_KEY_PATH="${HOME}/.ssh/source-vm.pem"   # key for source VM (jump host)
SSH_DEST_VM_KEY_PATH="${HOME}/.ssh/dest-vm.pem"       # key for dest VM; used locally via ProxyCommand

# ---- Storage ----------------------------------------------------------------

STORAGE_ACCOUNT_NAME="mystorageaccount"
STORAGE_CONTAINER_NAME="pipe-meter-results"

# ---- Test parameters --------------------------------------------------------

TEST_TYPE="both"                     # latency | throughput | both
ITERATIONS="8"
AUDIT_DIR="./audit"

# IS_BASELINE — set to true to write this run as the new reference baseline.
IS_BASELINE="false"

# COMPARE_BASELINE — set to true to download and compare with an existing baseline.
# Leave false (default) for a plain measurement run with no baseline interaction.
COMPARE_BASELINE="false"

# SESSION_ID — leave blank to auto-generate (recommended).
# SESSION_ID="pmeter_20260303T120000"
