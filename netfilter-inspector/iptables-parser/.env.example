# iptables-parser — environment variables for --explain and --explain-diff
#
# Copy relevant variables to your shell profile or a local .env file.
# NEVER commit GEMINI_API_KEY to version control.
#
# Usage:
#   export GEMINI_API_KEY=AIza...
#   python3 iptables_parser.py fw.txt --explain
#   python3 iptables_parser.py before.txt --explain-diff after.txt

# ---------------------------------------------------------------------------
# Required for --explain and --explain-diff
# ---------------------------------------------------------------------------

# Your Gemini API key. Obtain from https://aistudio.google.com/
# GEMINI_API_KEY=AIza...

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Gemini model to use for explanation generation.
# Default: gemini-2.0-flash
# Higher quality alternative: gemini-2.5-pro
# IPTABLES_EXPLAIN_MODEL=gemini-2.0-flash
