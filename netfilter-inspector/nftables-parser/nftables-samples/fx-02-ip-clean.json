{
  "nftables": [
    {"metainfo": {"version": "1.0.9", "release_name": "Old Doc Yak #3", "json_schema_version": 1}},
    {"table": {"family": "ip", "name": "filter", "handle": 1}},
    {"chain": {"family": "ip", "table": "filter", "name": "input",   "handle": 2, "type": "filter", "hook": "input",   "prio": 0, "policy": "accept"}},
    {"chain": {"family": "ip", "table": "filter", "name": "forward", "handle": 3, "type": "filter", "hook": "forward", "prio": 0, "policy": "accept"}},
    {"chain": {"family": "ip", "table": "filter", "name": "output",  "handle": 4, "type": "filter", "hook": "output",  "prio": 0, "policy": "accept"}},
    {
      "rule": {
        "family": "ip", "table": "filter", "chain": "output", "handle": 5,
        "expr": [
          {"match": {"op": "==", "left": {"payload": {"protocol": "ip",  "field": "daddr"}}, "right": "168.63.129.16"}},
          {"match": {"op": "==", "left": {"payload": {"protocol": "tcp", "field": "dport"}}, "right": 53}},
          {"accept": null}
        ]
      }
    },
    {
      "rule": {
        "family": "ip", "table": "filter", "chain": "output", "handle": 6,
        "expr": [
          {"match": {"op": "==", "left": {"payload": {"protocol": "ip", "field": "daddr"}}, "right": "168.63.129.16"}},
          {"match": {"op": "==", "left": {"meta": {"key": "l4proto"}}, "right": "tcp"}},
          {"match": {"op": "in", "left": {"ct": {"key": "state"}}, "right": ["established"]}},
          {"accept": null}
        ]
      }
    },
    {
      "rule": {
        "family": "ip", "table": "filter", "chain": "output", "handle": 7,
        "expr": [
          {"match": {"op": "==", "left": {"payload": {"protocol": "ip", "field": "daddr"}}, "right": "168.63.129.16"}},
          {"match": {"op": "==", "left": {"meta": {"key": "l4proto"}}, "right": "tcp"}},
          {"match": {"op": "in", "left": {"ct": {"key": "state"}}, "right": ["invalid", "new"]}},
          {"drop": null}
        ]
      }
    }
  ]
}
