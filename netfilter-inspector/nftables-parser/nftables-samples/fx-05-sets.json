{
  "nftables": [
    {"metainfo": {"version": "1.0.9", "release_name": "Old Doc Yak #3", "json_schema_version": 1}},
    {"table": {"family": "ip", "name": "filter", "handle": 1}},
    {"chain": {"family": "ip", "table": "filter", "name": "input", "handle": 2, "type": "filter", "hook": "input", "prio": 0, "policy": "accept"}},
    {
      "set": {
        "family": "ip", "table": "filter", "name": "blocklist", "handle": 10,
        "type": "ipv4_addr",
        "flags": ["interval"],
        "elem": [
          {"prefix": {"addr": "10.0.0.0",    "len": 8}},
          {"prefix": {"addr": "192.168.0.0", "len": 16}},
          {"prefix": {"addr": "172.16.0.0",  "len": 12}}
        ]
      }
    },
    {
      "map": {
        "family": "ip", "table": "filter", "name": "port-map", "handle": 11,
        "type": "inet_service",
        "map": "verdict"
      }
    },
    {
      "rule": {
        "family": "ip", "table": "filter", "chain": "input", "handle": 12,
        "expr": [
          {"match": {"op": "==", "left": {"payload": {"protocol": "ip", "field": "saddr"}}, "right": "@blocklist"}},
          {"drop": null}
        ]
      }
    },
    {
      "rule": {
        "family": "ip", "table": "filter", "chain": "input", "handle": 13,
        "expr": [
          {"match": {"op": "==", "left": {"payload": {"protocol": "ip", "field": "saddr"}}, "right": "@allowlist"}},
          {"accept": null}
        ]
      }
    }
  ]
}
