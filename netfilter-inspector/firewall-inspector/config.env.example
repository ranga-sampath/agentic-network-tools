# VM Firewall Inspector — config file
# Copy to config.env and fill in your values.
# Usage: python3 firewall_inspector.py --config config.env [--is-baseline | --compare-baseline SESSION_ID]
#
# Two provider modes:
#
#   PROVIDER=azure (default) — target is an Azure VM.
#     The probe runs via 'az vm run-command invoke'.
#     Requires VM_NAME, RESOURCE_GROUP, and Azure CLI authentication.
#
#   PROVIDER=ssh — target is any SSH-accessible Linux host.
#     The probe runs via direct SSH ('sudo bash -s').
#     Use for Multipass VMs, bare metal, or non-Azure hosts.
#     VM_NAME and RESOURCE_GROUP are not required.
#
# Two SSH topology cases (both providers):
#
#   Case 1 — Target VM has a public IP (direct SSH/SCP):
#     Set TARGET_VM_IP to the target VM's public IP.
#     Leave BASTION_PUBLIC_IP unset (comment it out or omit it).
#
#   Case 2 — Target VM has only a private IP (SSH/SCP via a bastion host):
#     Set TARGET_VM_IP to the target VM's private IP.
#     Set BASTION_PUBLIC_IP to the bastion host's public IP.
#     If the bastion and target use different SSH keys, also set BASTION_SSH_KEY_PATH.
#     If BASTION_SSH_KEY_PATH is omitted, TARGET_SSH_KEY_PATH is used for both hops.
#
# Rules:
#   - Lines starting with # are comments and are ignored.
#   - Values may be quoted (KEY="value") or unquoted (KEY=value).
#   - Inline comments are supported: KEY=value  # this is a comment
#   - Environment variables are expanded: TARGET_SSH_KEY_PATH="${HOME}/.ssh/id_rsa"
#   - CLI flags always override values in this file.

# ---------------------------------------------------------------------------
# Provider
# ---------------------------------------------------------------------------

PROVIDER=azure                        # azure (default) | ssh
                                      # azure: probe via az vm run-command invoke (requires VM_NAME, RESOURCE_GROUP)
                                      # ssh:   probe via direct SSH (Multipass, bare metal, non-Azure VMs)

# ---------------------------------------------------------------------------
# Required — target VM (both cases)
# ---------------------------------------------------------------------------

VM_NAME=prod-vm-01                    # Azure VM name to inspect
RESOURCE_GROUP=my-resource-group      # Azure resource group containing the VM
SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # Azure subscription ID
                                      # Omit if your account has only one subscription
                                      # or if az account set has already been run

# IP address of the VM to inspect.
# Case 1 (direct access):  use the target VM's public IP.
# Case 2 (via bastion):    use the target VM's private IP.
TARGET_VM_IP=10.0.0.5

# SSH private key for the target VM.
# Defaults to $INSPECTOR_VM_KEY or ~/.ssh/id_rsa if omitted.
TARGET_SSH_KEY_PATH="${HOME}/.ssh/id_rsa"

# ---------------------------------------------------------------------------
# Case 2 only — bastion (jump) host
# ---------------------------------------------------------------------------
# Omit or comment out these lines for Case 1 (direct access).

# BASTION_PUBLIC_IP=20.1.2.3          # Public IP of the bastion host
# BASTION_SSH_KEY_PATH="${HOME}/.ssh/bastion_key"  # SSH key for bastion; defaults to TARGET_SSH_KEY_PATH

# ---------------------------------------------------------------------------
# Optional — SSH and audit settings
# ---------------------------------------------------------------------------

SSH_USER=azureuser                    # SSH username for both target VM and bastion (default: azureuser)
AUDIT_DIR=./audit                     # Where to write snapshots and drift reports (default: ./audit)

# SESSION_ID=fw_prod_20260314         # Override auto-generated session ID
                                      # Auto-generated format: fw_YYYYMMDD_HHMMSS

# ---------------------------------------------------------------------------
# Optional — inspection mode
# ---------------------------------------------------------------------------
# Exactly one of IS_BASELINE or COMPARE_BASELINE should be set per run.
# IS_BASELINE=true      captures a new baseline snapshot.
# COMPARE_BASELINE=<id> diffs against a previously saved baseline.
# If neither is set, the tool captures and returns the current state without saving.

# IS_BASELINE=true
# COMPARE_BASELINE=fw_prod_20260314_100000

FAMILY=both                           # ipv4 | ipv6 | both (default: ipv4)

# ---------------------------------------------------------------------------
# Example — Multipass VM (PROVIDER=ssh)
# ---------------------------------------------------------------------------
# Uncomment and fill in to inspect a local Multipass VM.
# Get the VM's IP with: multipass info <vm-name>
# Prerequisites: SSH public key must be injected into the Multipass VM's
#   authorized_keys (see README for cloud-init instructions).
#
# PROVIDER=ssh
# TARGET_VM_IP=192.168.64.5            # from: multipass info <vm-name>
# TARGET_SSH_KEY_PATH="${HOME}/.ssh/id_rsa"
# SSH_USER=ubuntu                      # default user on Multipass VMs
# AUDIT_DIR=./audit
# FAMILY=both
# # VM_NAME and RESOURCE_GROUP are not required for PROVIDER=ssh
# # IS_BASELINE=true
# # COMPARE_BASELINE=fw_20260315_100000
